# Copy this file to .env and fill in your keys. The app runs in a graceful
# fallback mode without keys, but works best with them enabled.

# LLM provider is auto-selected: Groq > Gemini (first key present wins).
# Both are free. Pin one explicitly with LLM_PROVIDER to avoid an ambient
# shell key overriding your choice.
#   Gemini key: https://aistudio.google.com/apikey   (use model gemini-2.5-flash-lite)
#   Groq key:   https://console.groq.com/keys
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=

# Tavily live web search (https://tavily.com). Without it, trend queries skip
# the web-results portion (Semantic Scholar still works).
TAVILY_API_KEY=

# Semantic Scholar works with NO key. Optionally add one for higher rate limits.
SEMANTIC_SCHOLAR_API_KEY=

# SMTP for the email feature (sends the match summary to your own inbox).
# For Gmail, use an App Password, not your account password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
